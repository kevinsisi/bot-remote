# Slack App 的 Bot User OAuth Token(xoxb- 開頭)
SLACK_BOT_TOKEN=xoxb-...
# Slack App-Level Token(xapp- 開頭,scope: connections:write)
SLACK_APP_TOKEN=xapp-...
# 允許下指令的 Slack user ID,逗號分隔(在 Slack 個人檔案 → 複製成員 ID)
ALLOWED_USER_IDS=U0XXXXXXX
# 可選:只聽這個 channel(留空 = bot 所在的所有 channel)
CHANNEL_ID=
# 預設工作目錄
DEFAULT_CWD=D:\Projects
# 可選:claude CLI 指令名稱或完整路徑
CLAUDE_CMD=claude
# 可選:單一任務逾時(毫秒,預設 30 分鐘)
TASK_TIMEOUT_MS=
